@model List<Character>

@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    <h2>Список продуктов</h2>

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Имя</th>
                    <th>Книга</th>
                    <th>Автор</th>
                    <th>Роль</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var character in Model)
                {
                    <tr>
                        <td>@character.Id</td>
                        <td>@character.Name</td>
                        <td>@character.Book</td>
                        <td>@character.Author</td>
                        <td>
                            @if (character.Role == Character.RoleType.Main)
                            {
                                <span>Главный герой</span>
                            }
                            else if (character.Role == Character.RoleType.Secondary)
                            {
                                <span>Второстепенный</span>
                            }
                            else
                            {
                                <span>@character.Role</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Home" asp-action="Details" asp-route-id="@character.Id">Подробнее</a>
                        </td>
                        <td>
                            <a asp-controller="Home" asp-action="Update" asp-route-id="@character.Id">Обновить</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Нет доступных продуктов.</p>
    }
</div>